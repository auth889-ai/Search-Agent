# FindE AI environment example
# Copy this file to .env and fill real values.

NODE_ENV=development
PORT=8080
CLIENT_ORIGIN=http://localhost:5173

# Elasticsearch local
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Index names
COMMUNITY_POSTS_INDEX=finde_community_posts
WEB_SOURCES_INDEX=finde_web_sources
USER_KNOWLEDGE_INDEX=finde_user_knowledge



# Google Custom Search
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ENGINE_ID=

# Elastic MCP
ELASTIC_MCP_ENABLED=false
ELASTIC_MCP_SERVER_URL=

# Web search (optional — enables fresh internet results)
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=

# LLM answer composer (optional — Groq is free & fast). Falls back to
# extractive answers when absent. OpenRouter also supported.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Neural re-ranker (optional — Cohere Rerank, free trial tier). When set, the
# agent reorders the top results with a cross-encoder for better accuracy.
# No pip/Python needed — used via REST from Node. HF_TOKEN is NOT required
# (our embedding model is public and runs locally in Node).
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5

# Safety flags
ALLOW_VISIBLE_POST_INDEXING_ONLY=true
ALLOW_AUTO_SCROLL=false
ALLOW_HIDDEN_SCRAPING=false
