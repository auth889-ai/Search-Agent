{
  "manifest_version": 3,
  "name": "FindE AI — Community + Web Search Agent",
  "version": "0.1.0",
  "description": "Semantic fit-score search over community posts + web. Reads only the posts visible on your screen. No hidden scraping, no login bypass.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*",
    "https://*.facebook.com/*",
    "https://*.linkedin.com/*"
  ],
  "action": {
    "default_title": "FindE AI",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.facebook.com/*", "https://*.linkedin.com/*"],
      "js": ["extract-core.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
